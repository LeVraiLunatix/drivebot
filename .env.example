# ─── Shared ───────────────────────────────────────────────
# Postgres dédié à Drivebot (Render Postgres, Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/drivebot?schema=public"

# Secret partagé entre le dashboard et le bot pour l'API interne de reload de config
INTERNAL_API_SECRET="change-me-long-random-string"

# ─── Bot (apps/bot) ───────────────────────────────────────
DISCORD_TOKEN="your-bot-token"
DISCORD_CLIENT_ID="your-application-id"
# ID du serveur Discord Drivecord (déploiement rapide des slash commands en dev)
DISCORD_DEV_GUILD_ID=""
# Port du serveur HTTP de santé (Render fournit PORT automatiquement)
PORT="3001"

# ─── Dashboard (apps/dashboard) ───────────────────────────
# Auth.js v5
AUTH_SECRET="run: npx auth secret"
AUTH_DISCORD_ID="your-application-id"
AUTH_DISCORD_SECRET="your-oauth-client-secret"
# URL publique du bot pour déclencher un reload de config après sauvegarde
BOT_INTERNAL_URL="http://localhost:3001"
