# Variables du BOT (apps/bot). Copie ce fichier vers .env à la racine.

# Postgres dédié à Drivebot (Render Postgres, Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/drivebot?schema=public"

# Secret partagé bot <-> dashboard (génère une longue chaîne aléatoire, identique des deux côtés)
INTERNAL_API_SECRET=""

# Bot Discord (Developer Portal)
DISCORD_TOKEN=""
DISCORD_CLIENT_ID=""
# Optionnel : ID d'un serveur de dev pour déployer les slash commands instantanément
DISCORD_DEV_GUILD_ID=""

# Port du serveur HTTP de santé (Render fournit PORT automatiquement)
PORT="3001"
