// Drivebot — schéma de configuration par serveur Discord.
// Le dashboard écrit ces tables ; le bot les lit (avec cache + reload).

generator client {
  provider      = "prisma-client-js"
  // "native" pour le dev local ; "rhel-openssl-3.0.x" pour le runtime Vercel.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Un serveur Discord où Drivebot est présent. `id` = Discord guild ID.
model Guild {
  id        String   @id
  name      String?
  iconHash  String?
  locale    Locale   @default(FR)
  prefix    String   @default("!")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  welcome        WelcomeConfig?
  moderationCfg  ModerationConfig?
  ticketConfig   TicketConfig?
  verification   VerificationConfig?
  autoRoles      AutoRole[]
  embedTemplates EmbedTemplate[]
  modCases       ModerationCase[]
  tickets        Ticket[]
}

enum Locale {
  FR
  EN
}

/// Messages de bienvenue / départ + option embed.
model WelcomeConfig {
  guildId String  @id
  guild   Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)

  joinEnabled  Boolean @default(false)
  joinChannel  String?
  joinMessage  String  @default("Bienvenue {user} sur {server} ! 🎉")
  joinUseEmbed Boolean @default(false)
  joinEmbed    Json?

  leaveEnabled Boolean @default(false)
  leaveChannel String?
  leaveMessage String  @default("{username} a quitté le serveur.")

  updatedAt DateTime @updatedAt
}

/// Rôle(s) attribué(s) automatiquement à l'arrivée d'un membre.
model AutoRole {
  id      String @id @default(cuid())
  guildId String
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  roleId  String

  @@unique([guildId, roleId])
  @@index([guildId])
}

/// Réglages de modération et destination des logs.
model ModerationConfig {
  guildId    String  @id
  guild      Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)
  logEnabled Boolean @default(false)
  logChannel String?
  updatedAt  DateTime @updatedAt
}

/// Historique des actions de modération (warn/kick/ban/timeout).
model ModerationCase {
  id           String             @id @default(cuid())
  guildId      String
  guild        Guild              @relation(fields: [guildId], references: [id], onDelete: Cascade)
  type         ModerationAction
  targetUserId String
  moderatorId  String
  reason       String?
  createdAt    DateTime           @default(now())

  @@index([guildId, targetUserId])
}

enum ModerationAction {
  WARN
  KICK
  BAN
  UNBAN
  TIMEOUT
}

/// Embeds sauvegardés depuis l'embed builder du dashboard.
model EmbedTemplate {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  name      String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guildId])
}

/// Configuration du système de tickets (support).
model TicketConfig {
  guildId          String   @id
  guild            Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  enabled          Boolean  @default(false)
  panelChannel     String? // salon où est posté le panneau
  categoryId       String? // catégorie sous laquelle sont créés les tickets
  logChannel       String?
  staffRoleIds     String[] // rôles qui voient et gèrent les tickets
  pingRoleIds      String[] // rôles mentionnés à l'ouverture
  panelTitle       String   @default("Support")
  panelDescription String   @default("Besoin d'aide ? Clique sur le bouton ci-dessous pour ouvrir un ticket.")
  panelColor       Int      @default(5793266)
  buttonLabel      String   @default("Ouvrir un ticket")
  buttonEmoji      String   @default("🎫")
  openMessage      String   @default("Bonjour {user}, décris ta demande. Un membre du staff va te répondre.")
  maxOpen          Int      @default(1) // tickets ouverts max par membre
  counter          Int      @default(0) // compteur de numéros de ticket
  updatedAt        DateTime @updatedAt
}

/// Un ticket ouvert (salon privé).
model Ticket {
  id        String       @id @default(cuid())
  guildId   String
  guild     Guild        @relation(fields: [guildId], references: [id], onDelete: Cascade)
  number    Int
  channelId String       @unique
  userId    String
  status    TicketStatus @default(OPEN)
  claimedBy String?
  createdAt DateTime     @default(now())
  closedAt  DateTime?

  @@index([guildId, userId])
}

enum TicketStatus {
  OPEN
  CLOSED
}

/// Système de vérification (captcha à bouton) à l'entrée du serveur.
model VerificationConfig {
  guildId          String   @id
  guild            Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  enabled          Boolean  @default(false)
  channelId        String? // salon où est posté le panneau
  verifiedRoleId   String? // rôle donné après vérification
  unverifiedRoleId String? // rôle attribué à l'arrivée (retiré après vérif)
  panelTitle       String   @default("Vérification")
  panelDescription String   @default("Clique sur le bouton puis recopie le code affiché pour accéder au serveur.")
  panelColor       Int      @default(5793266)
  updatedAt        DateTime @updatedAt
}
