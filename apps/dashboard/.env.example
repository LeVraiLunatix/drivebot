# Copie vers apps/dashboard/.env.local (Next lit les .env de ce dossier).
# En prod (Vercel), définis ces variables dans le dashboard du projet.

# Auth.js v5 — génère le secret avec: npx auth secret
AUTH_SECRET=""

# Mot de passe unique pour entrer dans le dashboard (accès propriétaire)
DASHBOARD_PASSWORD=""

# Seul serveur Discord gérable (ID du serveur Drivecord)
DRIVECORD_GUILD_ID="1518687858335158466"

# Base Postgres dédiée au bot (identique à celle du bot)
DATABASE_URL="postgresql://user:password@host:5432/drivebot?schema=public"

# Communication avec le bot (mêmes valeurs que côté bot)
INTERNAL_API_SECRET="change-me-long-random-string"
# En prod : l'URL publique du bot sur Render (https://…onrender.com)
BOT_INTERNAL_URL="http://localhost:3001"
